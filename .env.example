# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# Macau DSEC API Authentication (Required)
# Get your APPCODE from: https://data.gov.mo
MACAO_DATA_APPCODE=your-appcode-here

# Output file path for tourist data (Optional)
# Default: data/data.json
MACAO_DATA_OUTPUT=data/data.json

# App info file path (Optional)
# Default: data/app.json
MACAO_DATA_APP_JSON=data/app.json
