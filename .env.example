# .env.example
# Copy this file to .env and fill in your actual values

# Macau DSEC API Authentication
# Get APPCODE from: https://data.gov.mo
MACAO_DATA_APPCODE=your-appcode-here

# Optional: Data range
FROM_YEAR=2008
TO_YEAR=2026

# Optional: Language preference (zh-MO, zh-CN, pt-PT, en-US)
DATA_LANG=zh-MO

